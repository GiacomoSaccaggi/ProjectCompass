# ProjectCompass Configuration
# Copy this file to .env and edit values

# Flask secret key (use a random string in production)
SECRET_KEY=change-me-to-a-random-string

# Admin credentials
# Generate hash: uv run python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Server
PORT=5000
FLASK_DEBUG=False

# GitLab integration
USE_GITLAB_REPO=False

# Ollama LLM (optional — app works without it)
OLLAMA_HOST=http://localhost:11434

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=*
